@using System.Timers
@using PomodoroFocus.Web.Components.Modals

<div class="timer-display-root">
    <div class="timer-container">
        <!-- Main Timer Display Area -->
        <div class="timer-visuals">
            <img src="@(TimerService.CurrentSessionType == SessionType.Pomodoro
                             ? "images/pomodoro_focus.svg"
                             : "images/break_chill.svg")"
                 alt="Timer Background"
                 class="timer-bg-image
            @(TimerService.CurrentState == TimerState.Running ? "pulsing" : "")
            @(TimerService.CurrentSessionType != SessionType.Pomodoro ? "break-image" : "")" />

            <div class="timer-text-overlay">
                @FormatTime(TimerService.RemainingSeconds)
            </div>
        </div>
    </div>
    <!-- Modal de configuración UC-08 -->
    <SettingsModal IsVisible="@ShowSettingsModal"
                   OnClose="@(() => ShowSettingsModal = false)" />
    <div class="timer-controls-wrapper">
        <TimerControls State="@TimerService.CurrentState"
                       CurrentSessionType="@TimerService.CurrentSessionType"
                       CompletedPomodoros="@TimerService.CompletedPomodoros"
                       OnStart="StartTimer"
                       OnStartBreak="@(() => TimerService.StartBreak())"
                       OnPause="PauseTimer"
                       OnResume="ResumeTimer"
                       OnCancel="RequestCancel" />
    </div>

    <!-- UC-08: Botón de configuración — ahora aquí abajo -->
    <div class="settings-action-wrapper">
        <button class="btn-settings-link"
                @onclick="OpenSettings"
                disabled="@IsTimerActive"
                title="@(IsTimerActive ? "Detén el timer para configurar" : "Configurar tiempos")">
            <svg class="settings-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            Configurar tiempos
        </button>
    </div>

    <!-- Modal: Cancelar sesión (existente) -->
    <PomodoroFocus.Web.Components.Modals.CancelConfirmModal
        IsVisible="@ShowCancelModal"
        OnClose="@(() => ShowCancelModal = false)"
        OnConfirmCompleted="HandleCompleted"
        OnConfirmNotCompleted="HandleNotCompleted" />

    <!-- Modal: Configuración UC-08 (nuevo) -->
    <SettingsModal
        IsVisible="@ShowSettingsModal"
        OnClose="@(() => ShowSettingsModal = false)" />
</div>

@using PomodoroFocus.Domain.Enums
@using PomodoroFocus.Application.Interfaces
@inject IPomodoroService TimerService
@inject IJSRuntime JSRuntime
@implements IDisposable

@code {
    // UI Local State
    private bool ShowCancelModal { get; set; } = false;
    private bool ShowSettingsModal { get; set; } = false; // UC-08

    // Pre-condición UC-08: timer no debe estar activo
    private bool IsTimerActive =>
        TimerService.CurrentState == TimerState.Running ||
        TimerService.CurrentState == TimerState.Break ||
        TimerService.CurrentState == TimerState.Paused;

    protected override void OnInitialized()
    {
        TimerService.OnTimerTick += HandleTimerTick;
        TimerService.OnSessionComplete += HandleSessionComplete;
    }

    private void HandleTimerTick()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionComplete()
    {
        JSRuntime.InvokeVoidAsync("playAudio", "alarm-sound");
        InvokeAsync(StateHasChanged);
    }

    private string FormatTime(int totalSeconds)
    {
        var time = TimeSpan.FromSeconds(totalSeconds);
        return $"{(int)time.TotalMinutes:D2}:{time.Seconds:D2}";
    }

    private void StartTimer() => TimerService.StartPomodoro();
    private void PauseTimer() => TimerService.Pause();
    private void ResumeTimer() => TimerService.Resume();

    // UC-08: Abrir settings
    private void OpenSettings()
    {
        if (!IsTimerActive)
            ShowSettingsModal = true;
    }

    private void RequestCancel()
    {
        if (TimerService.CurrentState == TimerState.Running) TimerService.Pause();
        ShowCancelModal = true;
    }

    private void HandleCompleted()
    {
        ShowCancelModal = false;
        TimerService.CancelAsCompleted();
    }

    private void HandleNotCompleted()
    {
        ShowCancelModal = false;
        TimerService.CancelAsIncomplete();
    }

    public void Dispose()
    {
        TimerService.OnTimerTick -= HandleTimerTick;
        TimerService.OnSessionComplete -= HandleSessionComplete;
    }
}

<audio id="alarm-sound" src="sounds/alarm.mp3" preload="auto"></audio>

<script>
    window.playAudio = (elementId) => {
        var audio = document.getElementById(elementId);
        if (audio) {
            audio.currentTime = 0;
            audio.play();
        }
    }
</script>
